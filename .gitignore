# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/

# 本地配置（含敏感信息）
config/config.yaml
config/config.local.yaml

# 日志和状态
logs/
*.log
*.err
state/
.state/

# 本地生成的 launchd plist（由 scripts/gen_launchd.py 生成，含机器路径）
launchd/*.plist

# 编辑器
.vscode/
.idea/
*.swp
*.swo

# 状态文件（运行时生成）
/tmp/*_state.json

# 数据库（SQLite）
data/*.db
data/*.db-shm
data/*.db-wal
data/backups/

# 持仓文件（含月薪、成本价等敏感信息）
positions.json

